{
  "name": "stackskills.sh",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "start": "next start",
    "dev": "pnpm db:up && next dev",
    "db:generate": "drizzle-kit generate",
    "db:generate:custom": "drizzle-kit generate --custom",
    "db:migration": "read -p 'Enter migration name: ' name && pnpm drizzle-kit generate --name \"${name// /_}\"",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "db:reset": "pnpm run db:down && docker volume rm stackskill-db && pnpm run db:up",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource/jersey-15": "^5.2.8",
    "@fontsource/jersey-25": "^5.2.8",
    "ai": "^6.0.116",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-shiki": "^0.9.2",
    "shadcn": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
